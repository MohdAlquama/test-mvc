<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Categories</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-r from-blue-100 to-blue-300 min-h-screen p-6">

  <!-- Header -->
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold text-gray-800">Categories</h1>

    <a href="/" class="bg-gray-700 hover:bg-gray-900 text-white px-4 py-2 rounded-lg text-sm">
      Home
    </a>
  </div>

  <!-- Description -->
  <p class="text-gray-700 mb-6">Manage your categories easily</p>

  <!-- Action Buttons -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

    <!-- Add Category -->
    <a href="/cat/categorie"
       class="bg-green-500 hover:bg-green-700 text-white p-6 rounded-xl shadow-md text-center text-lg font-semibold transition">
      ➕ Add Category
    </a>

    <!-- View Categories -->
    <a href="/cat/view-categorie"
       class="bg-blue-500 hover:bg-blue-700 text-white p-6 rounded-xl shadow-md text-center text-lg font-semibold transition">
      📋 View Categories
    </a>
    <a href="/cat/hotel"
       class="bg-purple-500 hover:bg-purple-700 text-white p-6 rounded-xl shadow-md text-center text-lg font-semibold transition">
      🏨 created Hotels
    </a>

  </div>

</body>
</html>