<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Hotel Welcome</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-r from-blue-100 to-blue-300 min-h-screen flex items-center justify-center">

  <!-- Card Container -->
  <div class="bg-white shadow-2xl rounded-2xl p-10 text-center w-[350px]">

    <!-- Title -->
    <h1 class="text-2xl font-bold text-gray-800 mb-6">
      Welcome to Hotel
    </h1>

    <!-- Buttons -->
    <div class="flex flex-col gap-4">

      <!-- Inside (Check In) -->
      <a href="/in" 
         class="bg-blue-500 hover:bg-blue-700 text-white font-semibold py-2 rounded-lg transition duration-300">
        Check In
      </a>

      <!-- Outside (Check Out or Exit) -->
            <a href="/exit" 
              class="bg-red-500 hover:bg-red-700 text-white font-semibold py-2 rounded-lg transition duration-300">
              Check Out
      </a>

      <a href="/filter" 
         class="bg-green-500 hover:bg-green-700 text-white font-semibold py-2 rounded-lg transition duration-300">
         Filter
      </a>
      <a href="/booking" 
         class="bg-yellow-500 hover:bg-yellow-700 text-white font-semibold py-2 rounded-lg transition duration-300">
         Booking
      </a>
    </div>

  </div>

</body>
</html>