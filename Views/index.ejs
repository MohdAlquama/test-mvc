<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Hotel Welcome</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-r from-blue-100 to-blue-300 min-h-screen flex flex-col items-center pt-10">

  <!-- Title -->
  <h1 class="text-3xl font-bold text-gray-800 mb-10">
    Welcome to Hotel
  </h1>

  <!-- Buttons Row -->
  <div class="w-full px-10">
    <div class="flex justify-between gap-4">

      <a href="/in" class="flex-1 text-center bg-blue-500 hover:bg-blue-700 text-white font-semibold py-3 rounded-lg">
        Check In
      </a>

      <a href="/exit" class="flex-1 text-center bg-red-500 hover:bg-red-700 text-white font-semibold py-3 rounded-lg">
        Check Out
      </a>

      <a href="/filter" class="flex-1 text-center bg-green-500 hover:bg-green-700 text-white font-semibold py-3 rounded-lg">
        Filter
      </a>

      <a href="/booking" class="flex-1 text-center bg-yellow-500 hover:bg-yellow-700 text-white font-semibold py-3 rounded-lg">
        Booking
      </a>

      <a href="/cat" class="flex-1 text-center bg-purple-500 hover:bg-purple-700 text-white font-semibold py-3 rounded-lg">
        Categories
      </a>
    </div>
  </div>

</body>
</html>