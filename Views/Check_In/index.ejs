<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Check In</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-r from-blue-100 to-blue-300 min-h-screen p-6">

  <!-- Title -->
  <h1 class="text-3xl font-bold text-gray-800 mb-6">
    Hotel Check In
  </h1>

  <!-- Full Width Form -->
  <form action="/check-in" method="POST" class="w-full bg-white p-6 rounded-xl shadow-lg">

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

      <div>
        <label class="block text-sm font-semibold mb-1">Name</label>
        <input type="text" name="name" class="w-full border rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-400">
      </div>

      <div>
        <label class="block text-sm font-semibold mb-1">Aadhar No</label>
        <input type="text" name="aadhar" maxlength="12" class="w-full border rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-400">
      </div>

      <div>
        <label class="block text-sm font-semibold mb-1">Phone No</label>
        <input type="tel" name="phone" maxlength="10" class="w-full border rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-400">
      </div>

      <div>
        <label class="block text-sm font-semibold mb-1">Number of People</label>
        <input type="number" name="people" min="1" class="w-full border rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-400">
      </div>

      <div>
        <label class="block text-sm font-semibold mb-1">Start Date</label>
        <input type="date" name="start_date" class="w-full border rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-400">
      </div>

      <div>
        <label class="block text-sm font-semibold mb-1">End Date</label>
        <input type="date" name="end_date" class="w-full border rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-400">
      </div>

    </div>

    <div class="mt-4">
      <label class="block text-sm font-semibold mb-1">Why choose this hotel</label>
      <textarea name="reason" rows="3" class="w-full border rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-400"></textarea>
    </div>

    <button type="submit" class="mt-6 w-full bg-blue-500 hover:bg-blue-700 text-white font-semibold py-3 rounded-lg">
      Check In
    </button>

  </form>

</body>
</html>