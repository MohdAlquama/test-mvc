<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Check In</title>
</head>
<body>

    <h1>Hotel Check In</h1>

    <form action="/check-in" method="POST">

        <!-- Name -->
        <label for="name">Name:</label>
        <input type="text" id="name" name="name" >
        <br><br>

        <!-- Aadhar Number -->
        <label for="aadhar">Aadhar No:</label>
        <input type="text" id="aadhar" name="aadhar" maxlength="12" >
        <br><br>

        <!-- Phone Number -->
        <label for="phone">Phone No:</label>
        <input type="tel" id="phone" name="phone" maxlength="10" >
        <br><br>

        <!-- Number of People -->
        <label for="people">Number of People:</label>
        <input type="number" id="people" name="people" min="1" >
        <br><br>

        <!-- Reason -->
        <label for="reason">Why choose this hotel:</label>
        <textarea id="reason" name="reason" rows="3" ></textarea>
        <br><br>

        <!-- Start Date -->
        <label for="start_date">Start Date:</label>
        <input type="date" id="start_date" name="start_date" >
        <br><br>

        <!-- End Date -->
        <label for="end_date">End Date:</label>
        <input type="date" id="end_date" name="end_date" >
        <br><br>

        <!-- Submit -->
        <button type="submit">Check In</button>

    </form>

</body>
</html>